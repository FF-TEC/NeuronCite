<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS application bundle metadata for NeuronCite.

  This file is a template used by the GitHub Actions release workflow.
  The __VERSION__ placeholder is replaced with the semantic version
  extracted from the git tag (e.g. "0.1.0") via sed at build time.

  The bundle is assembled in the release workflow as:
    NeuronCite.app/
      Contents/
        Info.plist          (this file, with version substituted)
        MacOS/neuroncite    (the compiled binary)
        Resources/AppIcon.icns  (icon.icns from this directory)

  CFBundleIconFile references "AppIcon" without extension; macOS
  automatically appends ".icns" and looks in Contents/Resources/.
  LSMinimumSystemVersion is 11.0 because wry/tao require WKWebView
  APIs available from macOS Big Sur onward.
-->
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>NeuronCite</string>

    <key>CFBundleDisplayName</key>
    <string>NeuronCite</string>

    <key>CFBundleIdentifier</key>
    <string>com.neuroncite.app</string>

    <key>CFBundleVersion</key>
    <string>__VERSION__</string>

    <key>CFBundleShortVersionString</key>
    <string>__VERSION__</string>

    <key>CFBundleExecutable</key>
    <string>neuroncite</string>

    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>

    <key>NSHighResolutionCapable</key>
    <true/>

    <key>NSHumanReadableCopyright</key>
    <string>Copyright 2026 NeuronCite Contributors. AGPL-3.0.</string>
</dict>
</plist>
